# .env.example — 이 파일을 .env로 복사 후 값 수정
# docker-compose.yml이 자동으로 .env를 로드함

# JWT 서명 키 (최소 32자, 운영 시 반드시 변경)
JWT_SECRET=stock-management-secret-key-for-development-only

# Spring Boot Admin 계정
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# 토스페이먼츠 API 키 (https://developers.tosspayments.com)
TOSS_SECRET_KEY=test_sk_placeholder
TOSS_CLIENT_KEY=test_ck_placeholder

# CORS 허용 출처 (콤마 구분 다중 도메인 가능)
CORS_ALLOWED_ORIGINS=http://localhost:3000
